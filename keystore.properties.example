# Bu dosyayı kopyalayıp "keystore.properties" adıyla kaydedin.
# keystore.properties dosyası .gitignore'da olduğu için git'e eklenmez.
# Kendi keystore yolunuzu ve şifrelerinizi yazın.

storeFile=release.keystore
storePassword=KEISTORE_SIFRENIZ
keyAlias=sssnap
keyPassword=KEY_SIFRENIZ

# Keystore proje dışındaysa tam yol kullanın (Windows'ta çift ters slash):
# storeFile=C:\\Users\\KULLANICI\\keystores\\release.keystore
